{
    "name": "@wzo/utils",
    "type": "module",
    "version": "0.0.5",
    "packageManager": "pnpm@10.34.4",
    "description": "",
    "author": "",
    "license": "ISC",
    "funding": "https://github.com/nowo/utils",
    "homepage": "https://github.com/nowo/utils",
    "repository": {
        "type": "git",
        "url": "https://github.com/nowo/utils"
    },
    "bugs": "https://github.com/nowo/utils/issues",
    "keywords": [
        "utils"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "dev": "unbuild --stub",
        "build": "unbuild",
        "prepack": "pnpm build",
        "test": "vitest",
        "typecheck": "tsc --noEmit",
        "docs:api": "typedoc",
        "docs:dev": "pnpm docs:api && vitepress dev docs",
        "docs:build": "pnpm docs:api && vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "lint:fix": "eslint . --fix"
    },
    "devDependencies": {
        "@types/node": "^22.20.0",
        "@wzo/eslint-config": "^0.0.3",
        "eslint": "^9.39.4",
        "typedoc": "^0.28.19",
        "typedoc-plugin-markdown": "^4.12.0",
        "typedoc-vitepress-theme": "^1.1.3",
        "typescript": "^5.9.3",
        "unbuild": "^3.6.1",
        "vitepress": "2.0.0-alpha.17",
        "vitest": "^4.1.9"
    }
}
