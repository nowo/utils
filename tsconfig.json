{
    "compilerOptions": {
        "target": "ESNext",
        "moduleDetection": "force",
        "module": "ESNext",
        "moduleResolution": "Bundler",

        "resolveJsonModule": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,

        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true
    },
    "include": [
        "src",
        "test"
    ]
}
